# Copy to airflow/.env and fill in. From your Databricks Free Edition workspace:
#   - HOST:  Server hostname, prefixed with https://
#   - TOKEN: User Settings -> Developer -> Access tokens -> Generate new token
#   - CATALOG: your Unity Catalog name (Free Edition default is usually "workspace")
#
# Free Edition is serverless — there is NO cluster id to set. Jobs run on serverless
# automatically because the DAG omits the cluster spec.
DATABRICKS_HOST=https://dbc-61ca3723-5fde.cloud.databricks.com
DATABRICKS_TOKEN=dapi_PUT_A_FRESH_ROTATED_TOKEN_HERE
DATABRICKS_CATALOG=workspace
