# Copy this file to ../.env and adjust if needed.
# The defaults in config.py already point at your Aiven service and the certs/ folder,
# so you only need this file if you want to override something.

KAFKA_BOOTSTRAP_SERVERS=kafka-3ca0846-adnananam1359-fbe9.f.aivencloud.com:12815

# Paths to the certs you downloaded into the certs/ folder.
# Defaults (relative to project root) already resolve to these — override only if needed.
# KAFKA_SSL_CA=certs/ca.pem
# KAFKA_SSL_CERT=certs/service.cert
# KAFKA_SSL_KEY=certs/service.key
